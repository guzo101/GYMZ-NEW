{
  "name": "gymz",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "postinstall": "node scripts/fix-expo-font-eclipse.js",
    "start": "node scripts/start-expo.cjs start",
    "start:lan": "node scripts/start-expo.cjs start --lan --port 8082",
    "start:tunnel": "node scripts/start-expo.cjs start --tunnel --port 8082",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:clear": "expo start --web --clear",
    "capture-bundle-error": "node scripts/capture-bundle-error.js",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "check-project": "npx expo-doctor && npm run lint && npm run type-check",
    "generate:notification-icon": "node scripts/generate-notification-icon.js",
    "build:apk": "npm run generate:icon && npm run generate:notification-icon && npx eas build --platform android --profile preview",
    "build:android": "npm run generate:icon && npm run generate:notification-icon && npx eas build --platform android --profile production",
    "build:ios:simulator": "npm run generate:icon && npm run generate:notification-icon && npx eas build --platform ios --profile preview-simulator",
    "build:ios:preview": "npm run generate:icon && npm run generate:notification-icon && npx eas build --platform ios --profile preview",
    "build:ios": "npm run generate:icon && npm run generate:notification-icon && npx eas build --platform ios --profile production",
    "generate:icon": "node scripts/generate-adaptive-icon.js",
    "prebuild": "npm run generate:icon && npx expo prebuild",
    "prebuild:ios": "npm run generate:icon && npx expo prebuild --platform ios"
  },
  "dependencies": {
    "@expo/vector-icons": "15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native/gradle-plugin": "^0.81.5",
    "@react-navigation/bottom-tabs": "^7.8.7",
    "@react-navigation/native": "^7.1.22",
    "@react-navigation/native-stack": "^7.8.1",
    "@supabase/supabase-js": "^2.86.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-blur": "^15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.4",
    "expo-haptics": "^15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "^8.0.11",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.16",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-paper": "^5.14.5",
    "react-native-qrcode-svg": "^6.3.20",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-preset-expo": "^54.0.9",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "validator": "^13.15.26"
  },
  "private": true
}
