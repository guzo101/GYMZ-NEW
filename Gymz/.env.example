# =============================================================================
# Gymz Environment Variables
# =============================================================================
# Copy this file to .env and fill in values. Never commit .env to git.
# See ENV_SETUP.md for full documentation.
# =============================================================================

# -----------------------------------------------------------------------------
# App / Expo (used at build time and runtime)
# -----------------------------------------------------------------------------
# Optional. App has fallbacks. Use to override for different environments.
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Build metadata (EAS often injects this automatically)
# EXPO_PUBLIC_BUILD_DATE=2025-03-04

# -----------------------------------------------------------------------------
# Pesapal (optional until production payments)
# -----------------------------------------------------------------------------
# Sandbox: https://cybqa.pesapal.com/pesapalv3/api
# Production: https://pay.pesapal.com/v3/api
# EXPO_PUBLIC_PESAPAL_BASE_URL=https://cybqa.pesapal.com/pesapalv3/api

# -----------------------------------------------------------------------------
# Expo CLI (local dev only — avoids flaky online dependency checks)
# -----------------------------------------------------------------------------
# EXPO_NO_DEPENDENCY_VALIDATION=1

# -----------------------------------------------------------------------------
# Dev scripts only (Node.js, NOT for app bundle)
# -----------------------------------------------------------------------------
# Required when running: check_policies_snapshots.js, ensure_bucket.js,
# verify_service_key.js, list_buckets_service.js, test_storage_direct.js
# Get from Supabase Dashboard → Settings → API → service_role key
# IMPORTANT: Rotate this key if it was ever committed to git.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
