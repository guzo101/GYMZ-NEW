# Supabase (public anon key is used in the client — keep RLS/policies aligned)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Leads: the site calls Edge Function `submit-website-inquiry` (insert + optional Make forward).
# Set secret WEBSITE_LEAD_WEBHOOK_URL in Supabase Dashboard → Edge Functions → Secrets (not in Vite).

# Pesapal config (example values only)
VITE_PESAPAL_CONSUMER_KEY=your_consumer_key
VITE_PESAPAL_CONSUMER_SECRET=your_consumer_secret
VITE_PESAPAL_IPN_ID=your_ipn_id
VITE_PESAPAL_IPN_URL=https://your-project.supabase.co/functions/v1/pesapal-ipn

# Optional local tunnel URL (for callbacks)
VITE_NGROK_URL=

# sandbox or production
VITE_PESAPAL_ENVIRONMENT=sandbox
